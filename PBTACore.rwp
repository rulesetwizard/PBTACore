    <LUACode>
function getAttributeValue()
	local nodeWin = window.windowlist.window.getDatabaseNode();
	local nodeAttr = DB.getChild(nodeWin, "attributes." .. window.attribute.getSelectedValue() .. ".value"); 
	Debug.console(nodeAttr);
	if nodeAttr then
		local attrValue = nodeAttr.getValue();
		if attrValue then
			return attrValue;
		end
	end
	return 0;
end</LUACode>
