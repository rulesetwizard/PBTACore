    <LUACode>function onDrop(x, y, draginfo)
	local sDragType = draginfo.getType();
	if sDragType == "string" or sDragType == "language" then
		local w = addEntry(true);
		w.name.setValue(draginfo.getStringData());
		return true;
	end
end</LUACode>
